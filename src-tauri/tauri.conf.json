{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AIKit",
  "version": "1.0.0",
  "identifier": "com.aikit.app",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AIKit",
        "width": 1000,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFNjg5NkU4QUIxREEyQzAKUldUQW9oMnI2SlpvVHA0UnRaZWJ6L080K2xKMDk1SW1SRng2T1BtY2RvUDBlRWlQUGFhWnN4Z24K",
      "endpoints": [
        "https://github.com/xian0316/aikit/releases/latest/download/latest.json"
      ]
    }
  }
}
